APP_NAME=alive-agent
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://alive_agent:change_me@postgres:5432/alive_agent

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_DOMAIN=https://open.feishu.cn
FEISHU_LONG_CONNECTION_ENABLED=false

DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4.1-mini
CHAT_CONTEXT_MESSAGES=10
CHAT_PROMPT_VERSION=chat_v2
COMMAND_REPAIR_PROMPT_VERSION=command_repair_v1
COMMAND_REPAIR_ENABLED=true
ALERT_DEFAULT_HOURS=72
ALERT_SCAN_INTERVAL_MINUTES=10
ADMIN_FEISHU_USER_ID=
ADMIN_TOKEN=change_me

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# 阶段 3 可用 OpenAI 兼容接口，例如 https://aihubmix.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# 阶段 3 仅保留 Anthropic / Gemini adapter 占位，不接真实调用

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

ALERT_SCHEDULER_ENABLED=false
